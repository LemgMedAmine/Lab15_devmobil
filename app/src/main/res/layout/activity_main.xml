<!-- Interface realisee par Lemghili Mohammed Amine -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/screen_background"
    android:fillViewport="true"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingLeft="@dimen/activity_horizontal_margin"
        android:paddingTop="28dp"
        android:paddingRight="@dimen/activity_horizontal_margin"
        android:paddingBottom="28dp">

        <TextView
            android:id="@+id/title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Gestion des etudiants"
            android:textColor="#FFFFFF"
            android:textSize="27sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/author"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center"
            android:text="Lemghili Mohammed Amine"
            android:textColor="#D6ECFF"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/form_panel"
            android:elevation="4dp"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:id="@+id/sectionAdd"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Ajouter un etudiant"
                android:textColor="#154064"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textView"
                style="@style/myStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nom"
                android:textColor="#4E5F6D"
                android:textSize="15sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/nom"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/input_background"
                android:hint="Ex: ALAMI"
                android:inputType="textCapWords"
                android:paddingLeft="14dp"
                android:paddingRight="14dp"
                android:textColor="#1C2B36"
                android:textColorHint="#8BA0AF"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/textView2"
                style="@style/myStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Prenom"
                android:textColor="#4E5F6D"
                android:textSize="15sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/prenom"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/input_background"
                android:hint="Ex: ALI"
                android:inputType="textCapWords"
                android:paddingLeft="14dp"
                android:paddingRight="14dp"
                android:textColor="#1C2B36"
                android:textColorHint="#8BA0AF"
                android:textSize="16sp" />

            <Button
                android:id="@+id/bn"
                style="@style/CrudButton"
                android:layout_marginTop="18dp"
                android:background="@drawable/button_add"
                android:text="Valider"
                android:textColor="#FFFFFF" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="22dp"
                android:layout_marginBottom="18dp"
                android:background="#DDE8EF" />

            <TextView
                android:id="@+id/sectionSearch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Chercher ou supprimer"
                android:textColor="#154064"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textView3"
                style="@style/myStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ID Etudiant"
                android:textColor="#4E5F6D"
                android:textSize="15sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/id"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/input_background"
                android:ems="10"
                android:hint="Ex: 1"
                android:inputType="numberSigned"
                android:paddingLeft="14dp"
                android:paddingRight="14dp"
                android:textColor="#1C2B36"
                android:textColorHint="#8BA0AF"
                android:textSize="16sp" />

            <Button
                android:id="@+id/load"
                style="@style/CrudButton"
                android:layout_marginTop="18dp"
                android:background="@drawable/button_search"
                android:text="Chercher"
                android:textColor="#FFFFFF" />

            <TextView
                android:id="@+id/res"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/result_background"
                android:gravity="center_vertical"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:text="Resultat de recherche"
                android:textColor="#24516B"
                android:textSize="18sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/delete"
                style="@style/CrudButton"
                android:layout_marginTop="14dp"
                android:background="@drawable/button_delete"
                android:text="Supprimer"
                android:textColor="#FFFFFF" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
